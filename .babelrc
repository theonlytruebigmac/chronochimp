{
  "presets": ["next/babel"],
  "plugins": [
    [
      "module-resolver",
      {
        "root": ["./"],
        "alias": {
          "@": "./src",
          "@/components": "./src/components",
          "@/lib": "./src/lib",
          "@/hooks": "./src/hooks",
          "@/types": "./src/types"
        }
      }
    ]
  ],
  "env": {
    "production": {
      "compact": true
    }
  }
}
