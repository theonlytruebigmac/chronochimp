# Version control
.git
.gitignore
.gitattributes

# Dependencies
node_modules
.pnp
.pnp.js

# Testing
coverage
__tests__
*.test.ts
*.test.tsx
jest.config.*

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local env files (but allow .env.production)
.env.local
.env.development
.env.development.local
.env.test
.env.test.local

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build output (but allow .next for deployment)
out
dist
build

# Docker
docker-compose*.yml
.dockerignore
!docker/entrypoint.sh

# Temporary files
*.log
*.bak
*.tmp

# Source control and documentation (not needed in production)
.git/
CHANGELOG.md
README.md
CONTRIBUTING.md
CHANGELOG.md

# Keep important config files
!next.config.ts
!tsconfig.json
!tailwind.config.ts
!postcss.config.mjs
!components.json
!package.json
!package-lock.json
!.babelrc

# Scripts directory needs to be included
!scripts/
!scripts/*

# Development configs - but we explicitly keep the ones we need above
*.config.js
